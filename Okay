local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService       = game:GetService("HttpService")

local LEVEL_DATA = ""

local MainLevels = require(ReplicatedStorage.Shared.Info.MainLevels)

for i, v in MainLevels do
    if v.id == 19 then
        table.remove(MainLevels, i)
        break
    end
end

local newLevel = {
    level_name  = "Unnamed 24",
    difficulty  = "Harder",
    stars       = 0,
    id          = 19,
    isDisplayed = true,
    level_data  = LEVEL_DATA,
}


table.insert(MainLevels, newLevel)

print("[Inject] ✅ Level 19 'Unnamed 24' injected!")
print("[Inject] level_data length :", #LEVEL_DATA)
print("[Inject] Total levels now  :", #MainLevels)


local ok, result = pcall(function()
    local Parser = require(ReplicatedStorage.Shared.Classes.Level.Parser)
    local settings, objects = Parser:LoadLevelData(LEVEL_DATA)
    return { settings, objects }
end)

if ok and type(result) == "table" then
    local settings, objects = result[1], result[2]
    print("[Inject] ✅ Parser validation passed!")
    if objects then
        print("[Inject] Objects parsed:", #objects)
    end
    if settings then
        print("[Inject] Gamemode:", settings.gamemode or "?")
        print("[Inject] Speed   :", settings.gameplaySpeed or "?")
    end
else
    warn("[Inject] ⚠ Parser validation failed:", tostring(result))
    warn("[Inject] Level was injected but may not render correctly.")
end


local success, encoded = pcall(function()
    return HttpService:JSONEncode(newLevel)
end)
if success then
    setclipboard(encoded)
    print("[Inject] ✅ Full level JSON copied to clipboard!")
else
    setclipboard(LEVEL_DATA)
    print("[Inject] ✅ Raw level_data string copied to clipboard!")
end
